{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20",
    "pnpm": "9"
  },
  "buildAptPackages": ["stockfish"],
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm --filter @omnira/db generate",
        "pnpm --filter @omnira/worker build"
      ]
    }
  },
  "deploy": {
    "aptPackages": ["stockfish"],
    "startCommand": "node --enable-source-maps apps/worker/dist/index.js"
  }
}
