{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20.20.2",
    "pnpm": "9.12.0"
  },
  "buildAptPackages": ["stockfish"],
  "steps": {
    "build": {
      "commands": [
        "pnpm --filter @omnira/db generate",
        "pnpm --filter @omnira/worker exec tsc -p tsconfig.json --noEmitOnError false || true",
        "test -f apps/worker/dist/index.js"
      ]
    }
  },
  "deploy": {
    "aptPackages": ["stockfish"],
    "startCommand": "node --enable-source-maps apps/worker/dist/index.js"
  }
}
