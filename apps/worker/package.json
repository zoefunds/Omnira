    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@omnira/chess-engine": "workspace:*",
    "@omnira/db": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
