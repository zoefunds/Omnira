{
  "name": "@omnira/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "start": "dotenv -e ../../.env -- node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "dotenv -e ../../.env -- vitest run",
    "test:watch": "dotenv -e ../../.env -- vitest"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@omnira/chess-engine": "workspace:^",
    "@omnira/db": "workspace:*",
    "@scure/base": "^1.1.9",
    "@scure/btc-signer": "^1.4.0",
    "argon2": "^0.41.1",
    "fastify": "^5.1.0",
    "genlayer-js": "^1.1.8",
    "ioredis": "^5.4.1",
    "socket.io": "^4.8.0",
    "viem": "^2.21.45",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
