// Omnira — Prisma schema
// Conventions:
//  - All IDs are UUID v4 (cuid would also work; UUID makes wallet derivation portable).
//  - Timestamps are UTC.
//  - Soft deletes via `deletedAt`. Hard delete only for GDPR.
//  - Enums for finite state machines (match status, time control, result).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── USER & AUTH ───────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  emailLower    String   @unique // for case-insensitive lookup
  username      String   @unique
  usernameLower String   @unique
  passwordHash  String   // argon2id — see Phase 3
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  wallet        Wallet?
  ratings       Rating[]
  matchesWhite  Match[]  @relation("WhitePlayer")
  matchesBlack       Match[]      @relation("BlackPlayer")
  challengesCreated      Challenge[]            @relation("ChallengesCreated")
  tournamentsCreated     Tournament[]           @relation("TournamentsCreated")
  tournamentsWon         Tournament[]           @relation("TournamentsWon")
  tournamentParticipations TournamentPlayer[]   @relation("TournamentParticipations")
  puzzleAttempts           PuzzleAttempt[]      @relation("PuzzleAttempts")
  puzzleRating             PuzzleRating?        @relation("PuzzleRating")
  challengesAccepted Challenge[]  @relation("ChallengesAccepted")
  chatMessages       ChatMessage[] @relation("ChatMessages")
  sessions      Session[]

  @@index([createdAt])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // sha256 of JWT jti — allows revocation
  userAgent String?
  ipHash    String?  // hashed for privacy
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId, expiresAt])
}

// ─────────────────────────── WALLET ───────────────────────────
// One wallet per user. Address is deterministically derived server-side
// from WALLET_MASTER_SECRET + userId. The privateKey is NEVER stored —
// it is re-derived in memory whenever the api/worker needs to sign.
// We store address + derivation metadata so we can audit/rotate later.

model Wallet {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @db.Uuid
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address             String   @unique // 0x-prefixed GenLayer address
  derivationVersion   String   // matches WALLET_DERIVATION_VERSION at signup time
  createdAt           DateTime @default(now())

  @@index([address])
}

// ─────────────────────────── RATING ───────────────────────────
// Separate Elo per time control. Glicko-2 can replace Elo later
// without schema changes — extra fields go into `metadata` JSON.

enum TimeControlCategory {
  BULLET
  BLITZ
  RAPID
  CLASSICAL
}

model Rating {
  id            String              @id @default(uuid()) @db.Uuid
  userId        String              @db.Uuid
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      TimeControlCategory
  rating        Int                 @default(1500)
  ratingDev     Int                 @default(350)   // RD for glicko, unused for plain Elo
  gamesPlayed   Int                 @default(0)
  updatedAt     DateTime            @updatedAt

  @@unique([userId, category])
  @@index([category, rating])
}

// ─────────────────────────── MATCH & MOVES ───────────────────────────

enum MatchStatus {
  PENDING      // matchmaking found pair, awaiting both clients
  ACTIVE
  WHITE_WON
  BLACK_WON
  DRAW
  ABORTED
}

enum MatchResultReason {
  CHECKMATE
  RESIGNATION
  TIMEOUT
  STALEMATE
  THREEFOLD_REPETITION
  FIFTY_MOVE_RULE
  INSUFFICIENT_MATERIAL
  AGREEMENT
  ABANDONMENT
}

model Match {
  id              String              @id @default(uuid()) @db.Uuid
  whitePlayerId   String              @db.Uuid
  blackPlayerId   String              @db.Uuid
  whitePlayer     User                @relation("WhitePlayer", fields: [whitePlayerId], references: [id])
  blackPlayer     User                @relation("BlackPlayer", fields: [blackPlayerId], references: [id])

  category        TimeControlCategory
  initialTimeSec  Int                 // base time per side
  incrementSec    Int                 // Fischer increment

  status          MatchStatus         @default(PENDING)
  resultReason    MatchResultReason?

  // Final position FEN (for quick rendering of completed games)
  finalFen        String?
  // PGN snapshot at completion
  pgn             String?

  // Elo deltas applied at end of game
  whiteRatingBefore Int?
  blackRatingBefore Int?
  whiteRatingAfter  Int?
  blackRatingAfter  Int?

  // GenLayer onchain tracking
  onchainMatchId    String?           // id returned by MatchRegistry contract
  onchainTxHash     String?
  onchainSettledAt  DateTime?

  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime            @default(now())

  moves           Move[]
  analysis        AnalysisReport?
  chat            ChatMessage[]
  challenge       Challenge?
  alternatives    Alternative[]
  puzzles         Puzzle[]
  tournamentId    String?      @db.Uuid
  tournament      Tournament?  @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([whitePlayerId])
  @@index([blackPlayerId])
}

model Move {
  id            String   @id @default(uuid()) @db.Uuid
  matchId       String   @db.Uuid
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ply           Int      // 1-indexed half-move number
  san           String   // e.g. "Nf3"
  uci           String   // e.g. "g1f3"
  fenAfter      String   // FEN after this move
  clockMsWhite  Int      // remaining time after move
  clockMsBlack  Int
  thinkMs       Int      // time spent on this move
  createdAt     DateTime @default(now())

  // Onchain (batched submission — set when the batch is mined)
  onchainBatchId String?
  onchainTxHash  String?

  @@unique([matchId, ply])
  @@index([matchId, ply])
}

// ─────────────────────────── AI ANALYSIS ───────────────────────────

model AnalysisReport {
  id              String   @id @default(uuid()) @db.Uuid
  matchId         String   @unique @db.Uuid
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // Stockfish output (per-ply eval, blunders, best moves)
  engineReport    Json
  // GenLayer LLM natural-language coaching
  llmSummary      String
  llmReport       Json
  // "What if I played X?" sims live here
  alternatives    Json     @default("[]")

  generatedAt     DateTime @default(now())
}

// ─────────────────────────── CHALLENGES (open lobby + private invites) ───────────────────────────

enum ChallengeColor {
  WHITE
  BLACK
  RANDOM
}

enum ChallengeStatus {
  OPEN
  ACCEPTED
  CANCELLED
  EXPIRED
}

model Challenge {
  id              String              @id @default(uuid()) @db.Uuid
  // Short share code, e.g. "M7QK2VPN". Used in /play/c/<code>.
  code            String              @unique
  creatorId       String              @db.Uuid
  creator         User                @relation("ChallengesCreated", fields: [creatorId], references: [id], onDelete: Cascade)

  category        TimeControlCategory
  initialMs       Int
  incrementMs     Int
  colorPreference ChallengeColor      @default(RANDOM)
  rated           Boolean             @default(true)
  isPublic        Boolean             @default(true)
  minRating       Int?
  maxRating       Int?

  status          ChallengeStatus     @default(OPEN)
  acceptedById    String?             @db.Uuid
  acceptedBy      User?               @relation("ChallengesAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  matchId         String?             @unique @db.Uuid
  match           Match?              @relation(fields: [matchId], references: [id], onDelete: SetNull)

  createdAt       DateTime            @default(now())
  expiresAt       DateTime
  updatedAt       DateTime            @updatedAt

  @@index([status, isPublic, createdAt])
  @@index([creatorId])
}

// ─────────────────────────── MATCH CHAT ───────────────────────────

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  matchId   String   @db.Uuid
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String   @db.Uuid
  sender    User     @relation("ChatMessages", fields: [senderId], references: [id], onDelete: Cascade)
  body      String   @db.VarChar(500)
  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
}

// ─────────────────────────── ALTERNATIVE-MOVE SIMS ───────────────────────────

enum AlternativeStatus {
  PENDING
  COMPLETE
  FAILED
}

model Alternative {
  id              String              @id @default(uuid()) @db.Uuid
  matchId         String              @db.Uuid
  match           Match               @relation(fields: [matchId], references: [id], onDelete: Cascade)

  ply             Int
  /// UCI form of the alternative move (e.g. "e2e4", "e7e8q")
  alternativeUci  String
  /// SAN of the alternative move once validated against fenBefore
  alternativeSan  String

  /// FEN of the position before the move at this ply (snapshot)
  fenBefore       String

  /// Eval AT THE ORIGINAL MOVE (for comparison)
  playedSan       String
  playedEvalCp    Int?
  playedEvalMate  Int?

  /// Eval AT THE ALTERNATIVE MOVE
  altEvalCp       Int?
  altEvalMate     Int?

  /// Centipawn delta vs played; positive = alternative is better for the mover
  cpDelta         Int?

  status          AlternativeStatus   @default(PENDING)
  errorMessage    String?
  createdAt       DateTime            @default(now())
  completedAt     DateTime?

  @@unique([matchId, ply, alternativeUci])
  @@index([status, createdAt])
  @@index([matchId, ply])
}

// ─────────────────────────── TOURNAMENTS (Arena) ───────────────────────────

enum TournamentFormat {
  ARENA
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  FINISHED
  CANCELLED
}

model Tournament {
  id              String              @id @default(uuid()) @db.Uuid
  name            String              @db.VarChar(120)
  format          TournamentFormat    @default(ARENA)

  createdById     String              @db.Uuid
  createdBy       User                @relation("TournamentsCreated", fields: [createdById], references: [id], onDelete: Cascade)

  category        TimeControlCategory
  initialMs       Int
  incrementMs     Int
  rated           Boolean             @default(true)

  /// Window start. Players can only join until startsAt.
  startsAt        DateTime
  /// Total length of the arena, in ms.
  durationMs      Int
  /// Convenience column = startsAt + durationMs; helps index queries.
  endsAt          DateTime

  status          TournamentStatus    @default(UPCOMING)
  /// Top player at finalization
  winnerId        String?             @db.Uuid
  winner          User?               @relation("TournamentsWon", fields: [winnerId], references: [id], onDelete: SetNull)

  /// Onchain registration / finalization tx hashes (Phase 11D)
  onchainTxHash       String?
  onchainSettledTxHash String?
  onchainSettledAt    DateTime?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  players         TournamentPlayer[]
  matches         Match[]

  @@index([status, startsAt])
  @@index([createdById])
}

model TournamentPlayer {
  id              String     @id @default(uuid()) @db.Uuid
  tournamentId    String     @db.Uuid
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId          String     @db.Uuid
  user            User       @relation("TournamentParticipations", fields: [userId], references: [id], onDelete: Cascade)

  /// Lichess-style arena points: win=2, draw=1, loss=0; bonus wins=4.
  score           Int        @default(0)
  wins            Int        @default(0)
  losses          Int        @default(0)
  draws           Int        @default(0)
  /// Consecutive wins. >=2 enables the streak (subsequent wins doubled).
  currentStreak   Int        @default(0)
  /// True when currentStreak >= 2 (so the NEXT win counts as a bonus win).
  hasStreakBonus  Boolean    @default(false)

  ratingAtStart   Int?
  joinedAt        DateTime   @default(now())
  /// User clicked "withdraw" mid-arena.
  withdrew        Boolean    @default(false)

  @@unique([tournamentId, userId])
  @@index([tournamentId, score(sort: Desc), wins(sort: Desc)])
}

// ─────────────────────────── PUZZLES ───────────────────────────

enum PuzzleAttemptResult {
  CORRECT
  WRONG
  SKIPPED
}

model Puzzle {
  id              String          @id @default(uuid()) @db.Uuid
  /// FEN of the position the user must solve.
  fen             String
  /// Whose move (parity from FEN, denormalized for cheap query).
  sideToMove      String          @db.VarChar(1)  // "w" | "b"
  /// Single-move solution (UCI). v2 may extend to multi-move PV.
  solutionUci     String
  /// SAN of the solution for display.
  solutionSan     String
  /// Stockfish eval of the position (mover POV cp; null if mate).
  evalCp          Int?
  evalMate        Int?
  /// What was actually played in the source game (the blunder).
  playedUci       String?
  playedSan       String?
  /// Centipawn-loss of the original blunder (severity heuristic).
  cpLoss          Int?
  /// Free-form tags: "blunder", "mate-in-1", "winning-material", "in-check"
  themes          String[]
  /// Glicko-lite rating; defaults to a midrange.
  rating          Int             @default(1500)
  ratingDev       Int             @default(350)
  attempts        Int             @default(0)
  solved          Int             @default(0)
  /// Where it came from — for credit / curation.
  sourceMatchId   String?         @db.Uuid
  sourceMatch     Match?          @relation(fields: [sourceMatchId], references: [id], onDelete: SetNull)
  sourcePly       Int?
  createdAt       DateTime        @default(now())
  publishedAt     DateTime?
  records         PuzzleAttempt[]

  @@index([rating])
  @@index([publishedAt])
  @@unique([sourceMatchId, sourcePly])
}

model PuzzleAttempt {
  id            String              @id @default(uuid()) @db.Uuid
  puzzleId      String              @db.Uuid
  puzzle        Puzzle              @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  userId        String              @db.Uuid
  user          User                @relation("PuzzleAttempts", fields: [userId], references: [id], onDelete: Cascade)
  result        PuzzleAttemptResult
  /// What the user submitted (UCI) — for analytics + replay.
  submittedUci  String?
  /// Rating snapshot AFTER this attempt.
  userRatingAfter   Int
  puzzleRatingAfter Int
  /// Milliseconds spent on this attempt.
  thinkMs       Int                 @default(0)
  createdAt     DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([puzzleId, createdAt])
}

model PuzzleRating {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @db.Uuid
  user          User     @relation("PuzzleRating", fields: [userId], references: [id], onDelete: Cascade)
  rating        Int      @default(1500)
  ratingDev     Int      @default(350)
  solved        Int      @default(0)
  attempted     Int      @default(0)
  updatedAt     DateTime @updatedAt
}

