{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20.20.2",
    "pnpm": "9.12.0"
  },
  "buildAptPackages": ["stockfish"],
  "steps": {
    "install": {
      "commands": [
        "corepack enable",
        "corepack prepare pnpm@9.12.0 --activate",
        "pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": [
        "pnpm --filter @omnira/db generate",
        "pnpm --filter @omnira/api build"
      ]
    }
  },
  "deploy": {
    "aptPackages": ["stockfish"],
    "startCommand": "node --enable-source-maps apps/api/dist/server.js"
  }
}
