# ───── App ─────
NODE_ENV=development
WEB_PORT=3000
API_PORT=4000

# ───── Postgres ─────
DATABASE_URL=postgresql://omnira:omnira@localhost:5432/omnira

# ───── Redis ─────
REDIS_URL=redis://localhost:6379

# ───── Auth ─────
# 32+ random bytes, hex. Generate with: openssl rand -hex 64
JWT_SECRET=replace_me_with_openssl_rand_hex_64
JWT_TTL=7d

# ───── Wallet derivation (CRITICAL — see docs/wallets.md) ─────
# Server-side master secret used to deterministically derive each user's GenLayer wallet.
# If this leaks, ALL user wallets are compromised. If you lose it, ALL users lose their wallets.
# Generate with: openssl rand -hex 64
WALLET_MASTER_SECRET=replace_me_with_openssl_rand_hex_64
WALLET_DERIVATION_VERSION=v1

# ───── GenLayer ─────
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_CHAIN_ID=
# Filled in AFTER you deploy in Phase 8
GENLAYER_MATCH_REGISTRY_ADDRESS=

# ───── AI ─────
STOCKFISH_PATH=/opt/homebrew/bin/stockfish
